screenshots/

# Tool-generated agent config. AGENTS.md is now a VibeFlow-generated engine file
# (committed as part of this repo's reference example); the rest stay ignored.
.github/skills/
.claude/*
!.claude/settings.json
!.claude/rules/
!.claude/rules/**
!.claude/CLAUDE.md
.opencode/

# Generated by `vf init` / `vf hooks emit`: per-machine absolute CLI/workspace
# paths. Same class as .claude/ above — never commit; `vf init` regenerates them.
/.mcp.json
/.codex/hooks.json
/.github/copilot-hooks.json
/.github/hooks/

# VibeFlow-generated per-engine agent files (regenerated by vf init).
# Engine dirs are views; canonical is .vibeflow/agents/ (future).
.codex/agents/
.claude/agents/
.github/agents/

# Tool session state / dispatch artifacts. Not source.
.hermes/
# Local vibeflow dispatch workunit state (no leading dot).
claude/
# But the reference templates under templates/ are committed source.
!templates/claude/
# lcov reports regenerated by `bun run check` (see scripts/coverage-gate.cjs).
coverage/
*.lcov
*.lcov.info
