{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(bun run *)",
      "Bash(bun test *)",
      "Bash(bunx *)",
      "Bash(git *)",
      "Bash(gh *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Read(.env)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["-e", "const t=JSON.parse(process.env.CLAUDE_TOOL_INPUT||'{}'); if(t.command&&/rm\\s+-rf/.test(t.command)){console.error('Blocked: rm -rf'); process.exit(2)}"]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write(*.ts)",
        "hooks": [
          {
            "type": "command",
            "command": "bunx",
            "args": ["biome", "format", "--write"]
          }
        ]
      },
      {
        "matcher": "Edit(*.ts)",
        "hooks": [
          {
            "type": "command",
            "command": "bunx",
            "args": ["biome", "format", "--write"]
          }
        ]
      }
    ]
  }
}