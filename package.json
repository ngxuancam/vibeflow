{
  "name": "@magicpro97/vibeflow",
  "version": "0.2.5",
  "description": "Local-first npm CLI that opens a web UI and orchestrates Claude Code, Codex CLI, and GitHub Copilot CLI with shared context, skills, hooks, and verification.",
  "type": "module",
  "bin": {
    "vf": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build ./src/cli.ts --target=node --outfile=dist/cli.js --banner='#!/usr/bin/env node' && chmod +x dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src test",
    "format": "biome format --write src test",
    "fix": "biome check --write src test",
    "test": "bun test",
    "test:e2e": "playwright test",
    "check": "bun run typecheck && bun run lint && bun run test",
    "prepare": "git config core.hooksPath .githooks || true",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "ai",
    "orchestrator",
    "claude-code",
    "codex",
    "copilot",
    "skills",
    "cli",
    "local-first"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magicpro97/vibeflow.git"
  },
  "homepage": "https://github.com/magicpro97/vibeflow#readme",
  "bugs": {
    "url": "https://github.com/magicpro97/vibeflow/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/cli": "^0.1.13",
    "@playwright/test": "^1.60.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
