---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('wiki');
  return entries.map((e) => ({ params: { slug: e.slug }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const allEntries = await getCollection('wiki');
const byCat = new Map<string, typeof allEntries>();
for (const e of allEntries) {
  const cat = e.data.category ?? 'uncategorized';
  if (!byCat.has(cat)) byCat.set(cat, []);
  byCat.get(cat)!.push(e);
}
const sortedCats = [...byCat.keys()].sort((a, b) => {
  if (a === 'uncategorized') return 1;
  if (b === 'uncategorized') return -1;
  return a.localeCompare(b);
});
for (const [cat, items] of byCat) {
  items.sort((a, b) => a.data.title.localeCompare(b.data.title));
}

const title = `${entry.data.title} — Wiki — VibeFlow`;
---

<Layout title={title} description={entry.data.description ?? ''} canonicalPath={`/wiki/${entry.slug}`}>
  <main id="main" class="wiki-layout">
    <aside class="wiki-sidebar">
      <nav class="sidebar-nav" aria-label="Wiki navigation">
        <a class="sidebar-home" href="/wiki/">← Wiki Index</a>
        {sortedCats.map((cat) => (
          <div class="sidebar-group">
            <h3 class="sidebar-cat">{cat.charAt(0).toUpperCase() + cat.slice(1)}</h3>
            <ul>
              {byCat.get(cat)!.map((e) => (
                <li>
                  <a
                    href={`/wiki/${e.slug}`}
                    class:list={['sidebar-link', { active: e.slug === entry.slug }]}
                  >
                    {e.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </aside>
    <article class="wiki-content">
      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
</Layout>

<style>
  .wiki-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 2rem;
    max-width: var(--maxw);
    margin-inline: auto;
    padding: 2rem 1.25rem;
    min-height: 80vh;
    align-items: start;
  }
  .wiki-sidebar {
    position: sticky;
    top: 1.5rem;
    max-height: calc(100vh - 3rem);
    overflow-y: auto;
    padding-right: 1rem;
    border-right: 1px solid var(--border-soft);
  }
  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .sidebar-home {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--text-dim);
    margin-bottom: 0.25rem;
  }
  .sidebar-group h3 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-faint);
    margin-bottom: 0.5rem;
    font-weight: 600;
  }
  .sidebar-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .sidebar-link {
    display: block;
    font-size: 0.88rem;
    color: var(--text-dim);
    padding: 0.3rem 0.4rem;
    border-radius: 6px;
    line-height: 1.35;
  }
  .sidebar-link:hover {
    color: var(--text);
    background: var(--bg-elev);
    text-decoration: none;
  }
  .sidebar-link.active {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    font-weight: 600;
  }
  .wiki-content {
    min-width: 0;
    padding-top: 0.5rem;
  }
  .prose {
    max-width: 820px;
    margin-inline: auto;
    line-height: 1.7;
    font-size: 1.02rem;
  }
  .prose :global(h1) {
    font-size: 2rem;
    margin-bottom: 1.25rem;
    color: var(--text);
  }
  .prose :global(h2) {
    font-size: 1.35rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border-soft);
    color: var(--text);
  }
  .prose :global(h3) {
    font-size: 1.15rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }
  .prose :global(p) {
    margin-bottom: 1rem;
    color: var(--text-dim);
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    color: var(--text-dim);
  }
  .prose :global(li) {
    margin-bottom: 0.4rem;
  }
  .prose :global(a) {
    color: var(--accent);
  }
  .prose :global(a:hover) {
    text-decoration: underline;
  }
  .prose :global(strong) {
    color: var(--text);
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin-left: 0;
    margin-bottom: 1rem;
    color: var(--text-dim);
    font-style: italic;
  }
  .prose :global(code) {
    background: var(--code-bg);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    color: var(--accent-2);
    font-family: var(--mono);
  }
  .prose :global(pre) {
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    max-width: 100%;
    margin-bottom: 1.25rem;
    font-size: 0.82rem;
    line-height: 1.6;
    scrollbar-width: thin;
  }
  .prose :global(pre)::-webkit-scrollbar {
    height: 8px;
  }
  .prose :global(pre)::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 4px;
  }
  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: var(--text);
    font-size: inherit;
  }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.25rem;
    font-size: 0.93rem;
  }
  .prose :global(th) {
    text-align: left;
    padding: 0.6rem 0.85rem;
    border-bottom: 2px solid var(--border);
    color: var(--text);
    font-weight: 600;
  }
  .prose :global(td) {
    padding: 0.55rem 0.85rem;
    border-bottom: 1px solid var(--border-soft);
    color: var(--text-dim);
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border-soft);
    margin: 2rem 0;
  }
  .prose :global(img) {
    max-width: 100%;
    border-radius: 8px;
  }
  .prose :global(img[src$=".svg"]) {
    display: block;
    width: 100%;
    margin: 1.5rem auto;
    padding: 1rem;
    background: #0a0d12;
    border: 1px solid var(--border);
    border-radius: 12px;
  }
  @media (max-width: 768px) {
    .wiki-layout {
      grid-template-columns: 1fr;
    }
    .wiki-sidebar {
      position: static;
      max-height: none;
      border-right: none;
      border-bottom: 1px solid var(--border-soft);
      padding-bottom: 1rem;
      padding-right: 0;
    }
    .sidebar-nav {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .sidebar-group {
      display: none;
    }
    .sidebar-home {
      margin-bottom: 0;
    }
  }
</style>
