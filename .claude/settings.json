{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(bun run *)",
      "Bash(bun test *)",
      "Bash(bunx *)",
      "Bash(git *)",
      "Bash(gh *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Read(.env)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["-e", "let c='';try{const t=JSON.parse(require('fs').readFileSync(0,'utf8')||'{}');c=t.tool_input&&t.tool_input.command||''}catch{process.exit(0)} if(/\\brm\\s+-[a-zA-Z]*r[a-zA-Z]*f|\\brm\\s+-[a-zA-Z]*f[a-zA-Z]*r/.test(c)){console.error('Blocked: rm -rf is denied by policy'); process.exit(2)}"]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write(*.ts)",
        "hooks": [
          {
            "type": "command",
            "command": "bunx",
            "args": ["biome", "format", "--write"]
          }
        ]
      },
      {
        "matcher": "Edit(*.ts)",
        "hooks": [
          {
            "type": "command",
            "command": "bunx",
            "args": ["biome", "format", "--write"]
          }
        ]
      }
    ]
  }
}