---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const entries = await getCollection('wiki');
const byCat = new Map<string, typeof entries>();
for (const e of entries) {
  const cat = e.data.category ?? 'uncategorized';
  if (!byCat.has(cat)) byCat.set(cat, []);
  byCat.get(cat)!.push(e);
}
const sortedCats = [...byCat.keys()].sort((a, b) => {
  if (a === 'uncategorized') return 1;
  if (b === 'uncategorized') return -1;
  return a.localeCompare(b);
});
for (const [, items] of byCat) {
  items.sort((a, b) => a.data.title.localeCompare(b.data.title));
}
---

<Layout
  title="Wiki — VibeFlow Documentation"
  description="VibeFlow documentation wiki — architecture, commands, guides, and reference material."
  canonicalPath="/wiki/"
>
  <main id="main" class="wiki-index container">
    <header class="wiki-header">
      <h1>Wiki</h1>
      <p class="wiki-sub">VibeFlow documentation &mdash; {entries.length} pages across {sortedCats.length} categories.</p>
    </header>

    {sortedCats.map((cat) => (
      <section class="wiki-section">
        <h2 class="cat-title">{cat.charAt(0).toUpperCase() + cat.slice(1)}</h2>
        <div class="cat-grid">
          {byCat.get(cat)!.map((e) => (
            <a class="wiki-card" href={`/wiki/${e.slug}`}>
              <h3>{e.data.title}</h3>
              {e.data.description && <p>{e.data.description}</p>}
            </a>
          ))}
        </div>
      </section>
    ))}
  </main>
</Layout>

<style>
  .wiki-index {
    padding-top: 3rem;
    padding-bottom: 4rem;
    min-height: 70vh;
  }

  .wiki-header {
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .wiki-header h1 {
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .wiki-sub {
    color: var(--text-dim);
    font-size: 1.05rem;
  }

  .wiki-section {
    margin-bottom: 2.5rem;
  }

  .cat-title {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-faint);
    margin-bottom: 0.85rem;
    font-weight: 600;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border-soft);
  }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.85rem;
  }

  .wiki-card {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border-soft);
    border-radius: 10px;
    padding: 1.1rem 1.25rem;
    transition: border-color 0.15s ease;
  }

  .wiki-card:hover {
    border-color: var(--accent);
    text-decoration: none;
  }

  .wiki-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.35rem;
    color: var(--text);
  }

  .wiki-card p {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.45;
    margin: 0;
  }
</style>
